{
  "name": "@sprintcx/openclaw-cliq",
  "version": "0.1.3",
  "description": "Native Zoho Cliq channel for OpenClaw — reply to DMs and channel @mentions as a bot, with streaming previews, cards, and message actions.",
  "type": "module",
  "license": "MIT",
  "author": "SprintCX",
  "homepage": "https://github.com/sprintberlin/openclaw-cliq#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sprintberlin/openclaw-cliq.git"
  },
  "bugs": {
    "url": "https://github.com/sprintberlin/openclaw-cliq/issues"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "openclaw-channel",
    "zoho",
    "zoho-cliq",
    "cliq",
    "chatbot",
    "bot"
  ],
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "default": "./dist/index.js"
    },
    "./setup-entry": {
      "default": "./dist/setup-entry.js"
    }
  },
  "files": [
    "dist",
    "index.ts",
    "setup-entry.ts",
    "src",
    "assets",
    "README.md",
    "openclaw.plugin.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "smoke:gateway": "bash scripts/smoke-gateway.sh"
  },
  "openclaw": {
    "extensions": ["./index.ts"],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "cliq",
      "label": "Zoho Cliq",
      "blurb": "Connect OpenClaw to Zoho Cliq."
    },
    "compat": {
      "pluginApi": ">=2026.6.6",
      "minGatewayVersion": "2026.6.6"
    },
    "build": {
      "openclawVersion": "2026.6.11"
    }
  },
  "devDependencies": {
    "openclaw": "^2026.6.11",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.6.6"
  }
}
