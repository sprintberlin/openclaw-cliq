{
  "name": "@sprintcx/openclaw-cliq",
  "version": "0.1.0",
  "description": "Zoho Cliq channel plugin for OpenClaw",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "default": "./dist/index.js"
    },
    "./setup-entry": {
      "default": "./dist/setup-entry.js"
    }
  },
  "files": [
    "dist",
    "index.ts",
    "setup-entry.ts",
    "src",
    "openclaw.plugin.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "smoke:gateway": "bash scripts/smoke-gateway.sh"
  },
  "openclaw": {
    "extensions": ["./index.ts"],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "cliq",
      "label": "Zoho Cliq",
      "blurb": "Connect OpenClaw to Zoho Cliq."
    },
    "compat": {
      "pluginApi": ">=2026.6.6",
      "minGatewayVersion": "2026.6.6"
    }
  },
  "devDependencies": {
    "openclaw": "^2026.6.11",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.6.6"
  }
}
