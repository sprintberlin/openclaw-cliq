{
  "id": "cliq",
  "kind": "channel",
  "channels": ["cliq"],
  "name": "Zoho Cliq",
  "description": "Zoho Cliq channel plugin for OpenClaw",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "clientId": { "type": "string" },
      "clientSecret": { "type": "string" },
      "botId": { "type": "string" },
      "botName": { "type": "string" },
      "webhookSecret": { "type": "string" },
      "refreshToken": { "type": "string" },
      "allowFrom": {
        "type": "array",
        "items": { "type": "string" }
      },
      "selfSenderIds": {
        "type": "array",
        "items": { "type": "string" }
      },
      "dmPolicy": {
        "type": "string",
        "enum": ["open", "allowlist", "pairing", "disabled"]
      },
      "ackPolicy": {
        "type": "string",
        "enum": ["after_dispatch", "immediate"],
        "default": "after_dispatch"
      },
      "groupPolicy": {
        "type": "string",
        "enum": ["open", "disabled", "allowlist"]
      },
      "groups": {
        "type": "object",
        "propertyNames": { "type": "string" },
        "additionalProperties": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "requireMention": { "type": "boolean" },
            "ingest": { "type": "boolean" },
            "tools": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "allow": { "type": "array", "items": { "type": "string" } },
                "alsoAllow": { "type": "array", "items": { "type": "string" } },
                "deny": { "type": "array", "items": { "type": "string" } }
              }
            },
            "toolsBySender": {
              "type": "object",
              "propertyNames": { "type": "string" },
              "additionalProperties": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "allow": { "type": "array", "items": { "type": "string" } },
                  "alsoAllow": { "type": "array", "items": { "type": "string" } },
                  "deny": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        }
      },
      "streaming": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "preview": { "type": "string", "enum": ["on", "off"], "default": "off" }
        }
      }
    }
  },
  "channelConfigs": {
    "cliq": {
      "schema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "clientId": { "type": "string" },
          "clientSecret": { "type": "string" },
          "botId": { "type": "string" },
          "botName": { "type": "string" },
          "webhookSecret": { "type": "string" },
          "refreshToken": { "type": "string" },
          "allowFrom": {
            "type": "array",
            "items": { "type": "string" }
          },
          "selfSenderIds": {
            "type": "array",
            "items": { "type": "string" }
          },
          "dmPolicy": {
            "type": "string",
            "enum": ["open", "allowlist", "pairing", "disabled"]
          },
          "ackPolicy": {
            "type": "string",
            "enum": ["after_dispatch", "immediate"],
            "default": "after_dispatch"
          },
          "groupPolicy": {
            "type": "string",
            "enum": ["open", "disabled", "allowlist"]
          },
          "groups": {
            "type": "object",
            "propertyNames": { "type": "string" },
            "additionalProperties": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "requireMention": { "type": "boolean" },
                "ingest": { "type": "boolean" },
                "tools": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "allow": { "type": "array", "items": { "type": "string" } },
                    "alsoAllow": { "type": "array", "items": { "type": "string" } },
                    "deny": { "type": "array", "items": { "type": "string" } }
                  }
                },
                "toolsBySender": {
                  "type": "object",
                  "propertyNames": { "type": "string" },
                  "additionalProperties": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                      "allow": { "type": "array", "items": { "type": "string" } },
                      "alsoAllow": { "type": "array", "items": { "type": "string" } },
                      "deny": { "type": "array", "items": { "type": "string" } }
                    }
                  }
                }
              }
            }
          },
          "streaming": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "preview": { "type": "string", "enum": ["on", "off"], "default": "off" }
            }
          }
        },
        "required": ["clientId", "clientSecret", "botId"]
      },
      "uiHints": {
        "clientId": { "label": "OAuth client id" },
        "clientSecret": { "label": "OAuth client secret", "sensitive": true },
        "botId": { "label": "Bot unique name" },
        "botName": { "label": "Bot display name" },
        "webhookSecret": { "label": "Webhook shared secret", "sensitive": true },
        "refreshToken": { "label": "User-context OAuth refresh token (required for channel posts / edits)", "sensitive": true },
        "allowFrom": { "label": "Allowed senders (Zoho Cliq user ids)" },
        "selfSenderIds": { "label": "Bot sender ids to ignore (self / other bots)" },
        "dmPolicy": { "label": "DM admission policy", "options": ["open", "allowlist", "pairing", "disabled"] },
        "ackPolicy": { "label": "Webhook ack timing", "options": ["after_dispatch", "immediate"] },
        "groupPolicy": { "label": "Group admission policy", "options": ["open", "allowlist", "disabled"] },
        "groups": { "label": "Per-group config (keyed by channel unique name)" },
        "streaming": { "label": "Streaming preview", "options": ["off", "on"] }
      }
    }
  }
}
