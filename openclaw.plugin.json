        "required": ["clientId", "clientSecret", "botId"]
      },
      "uiHints": {
        "clientId": { "label": "OAuth client id" },
        "clientSecret": { "label": "OAuth client secret", "sensitive": true },
        "botId": { "label": "Bot unique name" },
        "botName": { "label": "Bot display name" },
        "webhookSecret": { "label": "Webhook shared secret", "sensitive": true },
        "refreshToken": { "label": "User-context OAuth refresh token (required for channel posts / edits)", "sensitive": true },
        "allowFrom": { "label": "Allowed senders (Zoho Cliq user ids)" },
        "selfSenderIds": { "label": "Bot sender ids to ignore (self / other bots)" },
        "dmPolicy": { "label": "DM admission policy", "options": ["open", "allowlist", "pairing", "disabled"] },
        "ackPolicy": { "label": "Webhook ack timing", "options": ["after_dispatch", "immediate"] },
        "replyToMode": { "label": "Reply-to metadata mode (Cliq cannot render reply quotes; off = none, all = carry inbound id for correlation)", "options": ["off", "first", "all", "batched"] },
        "replyToModeByChatType": { "label": "Per-chat-type reply-to mode override (direct / group / channel)" },
        "groupPolicy": { "label": "Group admission policy", "options": ["open", "allowlist", "disabled"] },
        "groups": { "label": "Per-group config (keyed by channel unique name)" },
        "streaming": { "label": "Streaming preview", "options": ["off", "on"] },
        "reactions": { "label": "Agent reaction guidance", "options": ["minimal", "extensive", "off"] },
        "thinking": { "label": "Instant acknowledgement (default: animated dots placeholder; set mode or animate to \"off\" to disable)", "options": ["off", "placeholder", "card"] },
        "welcome": { "label": "Welcome message on subscribe (greeting DM on first contact)" },
        "pairing": { "label": "Pairing-approval card (post an Approve/Deny card to the bot owner when dmPolicy is pairing)" },
        "oauthBase": { "label": "OAuth base URL (data center — defaults to EU https://accounts.zoho.eu)" },
        "apiBase": { "label": "Cliq API base URL (data center — defaults to EU https://cliq.zoho.eu)" },
        "apiVersion": { "label": "REST API generation per family — string \"v2\"/\"v3\" (global override) OR object { dmPost?, channelPost?, channelCard?, delete? }. dmPost defaults to v3 (returns message id → thinking placeholder + DM live-edit); the other families default to v2. Leave unset for the built-in per-family defaults.", "options": ["v2", "v3"] }
      }
    }
  }
